generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model IncomeSource {
  id           String        @id @default(cuid())
  name         String
  category     CategoryType
  amount       Float
  isRecurring  Boolean       @default(true)
  payoutDate   Int?
  expectedDate DateTime?
  contractEndDate DateTime?
  isActive     Boolean       @default(true)
  ownerUserId  String?
  ownerUser    AppUser?      @relation("UserIncomeSources", fields: [ownerUserId], references: [id])
  transactions Transaction[]
}

model AppUser {
  id              String               @id @default(cuid())
  email           String               @unique
  displayName     String
  profilePhotoUrl String?
  bio             String?
  boothBasePrice  Float
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  uploadedSales   BoothMonthlySale[]   @relation("SaleUploader")
  boothOwnerships BoothOwnership[]
  gotFriendships  Friendship[]         @relation("FriendshipAddressee")
  sentFriendships Friendship[]         @relation("FriendshipRequester")
  incomeSources   IncomeSource[]       @relation("UserIncomeSources")
  gotProposals    JointBoothProposal[] @relation("ProposalPartner")
  sentProposals   JointBoothProposal[] @relation("ProposalRequester")
  nonBoothAssets  UserAsset[]          @relation("UserNonBoothAssets")
  boothTarget     UserBoothTarget?
  financeProfile  UserFinanceProfile?
  growthTargets   UserGrowthTarget[]
  notifications   UserNotification[]
}

model UserAsset {
  id             String    @id @default(cuid())
  ownerUserId    String
  type           AssetType
  name           String
  estimatedValue Float
  quantity       Float?
  unit           String?
  notes          String?
  acquiredAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  ownerUser      AppUser   @relation("UserNonBoothAssets", fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model UserFinanceProfile {
  id                           String              @id @default(cuid())
  userId                       String              @unique
  monthlyExpenseMin            Float               @default(1000000)
  monthlyExpenseMax            Float               @default(1000000)
  purchaseTiming               BoothPurchaseTiming @default(START_OF_MONTH)
  purchaseDayOverride          Int?
  openingBalance               Float               @default(0)
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  idleCashTarget               Float               @default(1000000000)
  renewEconomyBoothContracts   Boolean             @default(true)
  renewExclusiveBoothContracts Boolean             @default(true)
  user                         AppUser             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserGrowthTarget {
  id          String           @id @default(cuid())
  userId      String
  kind        GrowthTargetKind
  title       String
  targetValue Float
  currentValue Float           @default(0)
  unit        String
  note        String?
  deadline    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        AppUser          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
}

model UserNotification {
  id          String               @id @default(cuid())
  userId      String
  type        NotificationType
  priority    NotificationPriority @default(MEDIUM)
  title       String
  body        String
  href        String?
  readAt      DateTime?
  createdAt   DateTime             @default(now())
  metadata    Json?
  user        AppUser              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  addressee   AppUser          @relation("FriendshipAddressee", fields: [addresseeId], references: [id])
  requester   AppUser          @relation("FriendshipRequester", fields: [requesterId], references: [id])

  @@unique([requesterId, addresseeId])
}

model JointBoothProposal {
  id                    String             @id @default(cuid())
  requesterId           String
  partnerId             String
  boothName             String
  requesterCapital      Float
  partnerCapital        Float
  expectedMonthlyIncome Float
  status                ProposalStatus     @default(PENDING)
  selectedBoothType     BoothSelectionType
  notes                 String?
  proposedAt            DateTime           @default(now())
  reviewedAt            DateTime?
  reviewerNote          String?
  createdBoothId        String?            @unique
  mouSignedAt           DateTime           @default(now())
  packageType           BoothPackageType   @default(ECONOMY)
  referralEconomyBooths Int                @default(0)
  createdBooth          Booth?             @relation("CreatedFromProposal", fields: [createdBoothId], references: [id])
  partner               AppUser            @relation("ProposalPartner", fields: [partnerId], references: [id])
  requester             AppUser            @relation("ProposalRequester", fields: [requesterId], references: [id])
}

model Booth {
  id                               String              @id @default(cuid())
  name                             String
  expectedMonthlyIncome            Float
  mouDocumentName                  String?
  mouDocumentMimeType              String?
  mouDocumentData                  Bytes?
  isShared                         Boolean             @default(false)
  active                           Boolean             @default(true)
  createdAt                        DateTime            @default(now())
  updatedAt                        DateTime            @updatedAt
  mouSignedAt                      DateTime            @default(now())
  packageType                      BoothPackageType    @default(ECONOMY)
  referralCommissionPerBooth       Float               @default(250000)
  referralEconomyBooths            Int                 @default(0)
  boothUnitCount                   Int                 @default(1)
  contractDurationMonths           Int                 @default(24)
  economyProfitSharePct            Float               @default(30)
  exclusivePhase2StartsAfterMonths Int                 @default(96)
  exclusiveRenewalCapital          Float               @default(20000000)
  exclusiveSharePhase1Pct          Float               @default(40)
  exclusiveSharePhase2Pct          Float               @default(60)
  monthlySales                     BoothMonthlySale[]
  ownerships                       BoothOwnership[]
  createdByProposal                JointBoothProposal? @relation("CreatedFromProposal")
}

model BoothOwnership {
  id              String   @id @default(cuid())
  boothId         String
  userId          String
  capitalAmount   Float
  revenueSharePct Float
  createdAt       DateTime @default(now())
  booth           Booth    @relation(fields: [boothId], references: [id], onDelete: Cascade)
  user            AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boothId, userId])
}

model BoothMonthlySale {
  id           String   @id @default(cuid())
  boothId      String
  month        Int
  year         Int
  grossIncome  Float
  netIncome    Float?
  uploadedById String
  uploadedAt   DateTime @default(now())
  booth        Booth    @relation(fields: [boothId], references: [id], onDelete: Cascade)
  uploadedBy   AppUser  @relation("SaleUploader", fields: [uploadedById], references: [id])

  @@unique([boothId, month, year])
}

model UserBoothTarget {
  id                    String   @id @default(cuid())
  userId                String   @unique
  targetBoothEquivalent Int
  revenuePerBooth       Float    @default(1000000)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String        @id @default(cuid())
  type            TxType
  amount          Float
  date            DateTime      @default(now())
  description     String
  sourceId        String?
  expenseCategory String?
  source          IncomeSource? @relation(fields: [sourceId], references: [id])
}

model BudgetLimit {
  id               String @id @default(cuid())
  category         String @unique
  maxLimit         Float
  warningThreshold Float
}

model SavingGoal {
  id            String   @id @default(cuid())
  name          String
  targetAmount  Float
  currentAmount Float    @default(0)
  deadline      DateTime
  priority      Int
}

enum CategoryType {
  BOOTH
  SAAS
  SALARY
  PROJECT
  COMMISSION
  STOCK
}

enum TxType {
  INCOME
  EXPENSE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BoothSelectionType {
  NEW_BOOTH
  EXISTING_BOOTH
}

enum BoothPurchaseTiming {
  START_OF_MONTH
  END_OF_MONTH
}

enum BoothPackageType {
  EXCLUSIVE
  ECONOMY
}

enum AssetType {
  GOLD
  PROPERTY
  OTHER
}

enum GrowthTargetKind {
  ACCOUNT_COUNT
  CAPITAL_POOL
  CUSTOM
}

enum NotificationType {
  SYSTEM
  FINANCE
  COLLABORATION
  SOCIAL
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
}
